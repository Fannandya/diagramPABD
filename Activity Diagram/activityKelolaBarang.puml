@startuml activityKelolaBarang
|Admin|
start
:Membuka aplikasi;

|Sistem|
:Tampilkan halaman login;

|Admin|
:Login dengan username dan password;

|Sistem|
:Validasi Akun;
if (Login Berhasil?) then (Ya)
  :Tampilkan Halaman Utama;
else (Tidak)
  :Tampilkan Pesan Error;
  :Kembali ke Halaman Login;
  detach
endif

|Admin|
:Pilih menu Kelola Barang;

|Sistem|
:Tampilkan halaman Kelola Barang;

|Admin|
if (Ingin Tambah Barang?) then (Ya)
  |Sistem|
  repeat
    :Tampilkan form tambah barang;
    |Admin|
    :Input data barang;
    :Klik Simpan;
    |Sistem|
    if (Input Valid?) then (Ya)
      :Simpan data permintaan ke satprasDB;
      :Tampilkan notifikasi sukses;
    else (Tidak)
      :fail safe;
      :Tampilkan pesan error;
    endif
    |Admin|
  repeat while (Tambah barang lagi?) is (Ya)
  ->Tidak;
  :Kembali ke halaman Kelola Barang;
else (Tidak)
endif

stop
@enduml