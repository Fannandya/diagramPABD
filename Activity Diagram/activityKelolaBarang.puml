@startuml activityKelolaBarang
|Admin|
start
:Pilih menu Kelola Barang;

|UI|
:Request data barang ke BLL;

|BLL|
:ambil data dari DAL;

|DAL|
:Kirim data ke BLL;

|BLL|
:Kirim data ke UI;

|UI|
:Tampilkan daftar barang;

|Admin|
if (Tambah Barang?) then (Ya)
  :Input data barang;
  :Klik Simpan;
  |UI|
  :Kirim data ke BLL;
  |BLL|
  :Validasi input (tidak kosong);
  |DAL|
  :Simpan ke Database;
  |BLL|
  :Kirim konfirmasi ke UI;
  |UI|
  :Tampilkan Konfirmasi Berhasil;
else (Tidak)
endif
stop
@enduml