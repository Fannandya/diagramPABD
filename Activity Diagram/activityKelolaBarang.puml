@startuml activityKelolaBarang
|Admin|
start
:Membuka aplikasi;

|Sistem|
:Tampilkan halaman login;

|Admin|
:Login dengan username dan password;

|Sistem|
:Validasi login;

|Admin|
:Pilih menu Kelola Barang;

|Sistem|
:Tampilkan halaman Kelola Barang;

|Admin|
if (Ingin Tambah Barang?) then (Ya)
  |Sistem|
  repeat
    :Tampilkan form tambah barang;
    |Admin|
    :Input data barang;
    :Klik Simpan;
    |Sistem|
    :Proses simpan & tampilkan konfirmasi;
    |Admin|
  repeat while (Tambah barang lagi?) is (Ya)
  ->Tidak;
  :Kembali ke halaman Kelola Barang;
else (Tidak)
endif

stop
@enduml