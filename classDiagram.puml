@startuml classDiagram
skinparam classAttributeIconSize 0
skinparam Style strictuml

' --- Master Layer ---

class Semester {
  + idSemester : int
  + tahunAjaran : string
  ..
  + tambah() : void
}

class Karyawan {
  + idKaryawan : int
  + namaKaryawan : string
  ..
  + getKaryawan() : list
}

class Gedung {
  + idGedung : int
  + namaGedung : string
  ..
  + tambahGedung() : void
}

class Ruangan {
  + idRuangan : int
  + idGedung : int
  + namaRuangan : string
  ..
  + getRuangan() : list
}

class Barang {
  + idBarang : int
  + namaBarang : string
  + stok : int
  + tipeBarang : bool
  ..
  + cekStok() : int
}

' --- Transaction Layer ---

class Users {
  + idUser : int
  + email : string
  - password : string
  ..
  + login() : bool
}

class DetailBarang {
  + idDetailBarang : int
  + idBarang : int
  + idRuangan : int
  ..
  + getDetail() : list
}

class PermintaanBarang {
  + idPermintaanBarang : int
  + idBarang : int
  + idRuangan : int
  + idSemester : int
  + namaPeminta : string
  + jumlah : int
  + tglPermintaan : date
  ..
  + simpan() : void
}

class Maintenance {
  + idMaintenance : int
  + idKaryawan : int
  + idDetailBarang : int
  + idSemester : int
  + tglCek : date
  + kondisi : bool
  + kerusakan : string
  + tindakLanjut : string
  ..
  + simpan() : void
}

class Report {
  + idReport : int
  + idMaintenance : int
  + idPermintaanBarang : int
  + idSemester : int
  + tglReport : date
  ..
  + generateExcel() : void
}

' --- Relasi Sesuai SQL ---

Gedung "1" -- "*" Ruangan : memiliki >
Ruangan "1" -- "*" DetailBarang : menyimpan >
Barang "1" -- "*" DetailBarang : memiliki >

Barang "1" -- "*" PermintaanBarang : diminta >
Ruangan "1" -- "*" PermintaanBarang : lokasi >
Semester "1" -- "*" PermintaanBarang : periode >

Karyawan "1" -- "*" Maintenance : mengecek >
DetailBarang "1" -- "*" Maintenance : dirawat >
Semester "1" -- "*" Maintenance : periode >

Maintenance "1" -- "*" Report : data >
PermintaanBarang "1" -- "*" Report : data >
Semester "1" -- "*" Report : periode >

@enduml