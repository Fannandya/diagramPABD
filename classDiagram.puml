@startuml classDiagram
skinparam classAttributeIconSize 0
skinparam Style strictuml

' --- Master Data ---

class User {
  + id_user : int
  + username : string
  - password : string
  ..
  + login() : bool
  + logout() : void
}

class Barang {
  + id_barang : int
  + nama_barang : string
  + tipe_barang : string
  + stok : int
  ..
  + tambah() : void
  + update() : void
  + hapus() : void
}

class Gedung {
  + id_gedung : int
  + nama_gedung : string
  ..
  + tambahGedung() : void
}

class Ruangan {
  + id_ruangan : int
  + id_gedung : int
  + nama_ruangan : string
  ..
  + getRuanganByGedung() : list
}

class Karyawan {
  + id_karyawan : int
  + nama_karyawan : string
  + jabatan : string
  ..
  + getKaryawan() : list
}

' --- Transactional / Detail ---

class DetailBarang {
  + id_detail : int
  + id_barang : int
  + id_ruangan : int
  ..
  + updateLokasi() : void
  + getDetailByBarang() : list
}

class Peminjaman {
  + id_pinjam : int
  + id_detail : int
  + nama_peminjam : string
  + jumlah : int
  + tgl_pinjam : date
  ..
  + simpan() : void
  + cetakBukti() : void
}

class Maintenance {
  + id_mt : int
  + id_detail : int
  + id_karyawan : int
  + tgl_mt : date
  + kondisi : string
  + tindak_lanjut : string
  ..
  + simpan() : void
  + updateStatus() : void
}

class Report {
  + tgl_generate : datetime
  ..
  + requestData() : void
  + exportToExcel() : void
}

' --- Relasi Sesuai Kardinalitas RAT ---

Barang "1" -- "*" DetailBarang : memiliki >
Gedung "1" -- "*" Ruangan : memiliki >
Ruangan "1" -- "0..*" DetailBarang : menyimpan >

DetailBarang "1" -- "*" Peminjaman : diminta >
DetailBarang "1" -- "*" Maintenance : dirawat >
Karyawan "1" -- "*" Maintenance : melakukan >

Report ..> DetailBarang : mengambil data >
Report ..> Peminjaman : mengambil data >

@enduml